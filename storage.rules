rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /uploads/{allPaths=**} {
      // Permite leitura pública de imagens enviadas
      allow read: if true;
      // Permite upload por usuários autenticados (incluindo anônimos)
      allow write: if request.auth != null && request.resource.size < 5 * 1024 * 1024;
    }
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
